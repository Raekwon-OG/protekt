// filepath: apps/api/prisma/schema.prisma
// Prisma schema for Protekt MVP: Org and User models.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Org {
  id        String  @id @default(cuid())
  name      String  @unique
  slug      String? @unique
  createdAt DateTime @default(now())
  users     User[]
  memberships Membership[]
}

model User {
  id           String  @id @default(cuid())
  fullName     String?
  email        String  @unique
  passwordHash String
  role         String  @default("USER")
  orgId        String?
  org          Org?     @relation(fields: [orgId], references: [id])
  memberships  Membership[]
  createdAt    DateTime @default(now())
}

model Membership {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  org       Org      @relation(fields: [orgId], references: [id])
  orgId     String
  role      String
  createdAt DateTime @default(now())

  @@unique([userId, orgId])
}

model EmailScanLog {
  id             String   @id @default(cuid())
  from           String?
  subject        String?
  text           String?
  urls           Json
  verdictSummary String
  phishingCount  Int      @default(0)
  details        Json
  orgId          String?      // optional if you may not have org context
  createdByUserId String?     // optional — remove if not in schema
  createdAt      DateTime @default(now())
}

model Device {
  id           String   @id @default(uuid())
  orgId        String
  name         String
  type         String
  status       String?   // e.g., Online / Offline
  agentVersion String?
  risk         String?   // Low / Medium / Critical
  lastSeen     DateTime? @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  revoked      Boolean   @default(false)

  // If you have an Organization/Org model, uncomment the relation below and adjust the field name
  // org        Organization @relation(fields: [orgId], references: [id])
  @@index([orgId])
}

model DeviceTelemetry {
  id        String   @id @default(cuid())
  deviceId  String
  orgId     String
  payload   Json
  createdAt DateTime @default(now())

  @@index([deviceId])
  @@index([orgId])
}

